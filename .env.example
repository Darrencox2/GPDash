# GPDash environment variables — example
# Copy this file to .env.local for local development (gitignored, never commit real values).
# In production: paste these into Vercel project Settings → Environment Variables.

# Supabase (v4 onwards) -----------------------------------------------------
# From: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Upstash Redis (v3 — kept until v4 migration completes) --------------------
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# App password (v3 — replaced by Supabase Auth in v4) ----------------------
APP_PASSWORD=your-shared-practice-password
